# ── Required ──────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Optional — API ────────────────────────────────────────────────────────────
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_TIMEOUT=120

# ── Optional — Editor behaviour ───────────────────────────────────────────────
# EDITOR_MODEL=claude-sonnet-4-6
# EDITOR_MAX_TOKENS=8192
# EDITOR_DECISION_TIMEOUT=300
# EDITOR_BATCH_WORDS=800

# ── Optional — Server limits ──────────────────────────────────────────────────
# MAX_UPLOAD_MB=5
# MAX_SESSIONS=100

# ── Optional — CORS (only needed when API is on a different domain) ───────────
# CORS_ORIGINS=https://yourdomain.com
